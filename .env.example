# Copy to .env.local and fill in values for local development.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Discogs
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Resend (email)
RESEND_API_KEY=

# Anthropic (Claude SDK — deep dive, dig, insights, playlist gen)
ANTHROPIC_API_KEY=

# Ticketmaster (gigs lookup)
TICKETMASTER_API_KEY=

# Amazon affiliate (optional)
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=
NEXT_PUBLIC_AMAZON_ONELINK_ID=

# Sentry error monitoring (optional — app runs fine with these unset)
# DSN used by client/server/edge to report errors.
NEXT_PUBLIC_SENTRY_DSN=
# Server-only DSN override; falls back to NEXT_PUBLIC_SENTRY_DSN if unset.
SENTRY_DSN=
# Only needed to enable source map upload during `next build`.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
